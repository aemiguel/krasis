#!/usr/bin/env bash
#
# Krasis — repo entry point.
#
# For development, use ./dev (handles build, benchmark, test, etc.)
# For end-user installs, use install.sh (creates ~/.local/bin/krasis)
#
# This script exists so you can run ./krasis from the repo directory.
# It delegates immediately to the Python launcher — no venv creation,
# no pip installs, no dependency checks. That's what ./dev and
# install.sh are for.
#
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_PYTHONPATH="$SCRIPT_DIR/python"
REPO_LIBPATH="$SCRIPT_DIR/python/krasis.libs"

exec_repo_launcher() {
    local python_bin="$1"
    shift
    local ld_path="${LD_LIBRARY_PATH:-}"
    if [[ -d "$REPO_LIBPATH" ]]; then
        ld_path="$REPO_LIBPATH${ld_path:+:$ld_path}"
    fi
    exec env PYTHONNOUSERSITE=1 PYTHONPATH="$REPO_PYTHONPATH${PYTHONPATH:+:$PYTHONPATH}" \
        LD_LIBRARY_PATH="$ld_path" "$python_bin" -m krasis.launcher "$@"
}

# Use conda env if available (dev machines), else system python
CONDA_PY="$HOME/miniconda3/envs/ktransformers/bin/python"
if [[ -x "$CONDA_PY" ]]; then
    exec_repo_launcher "$CONDA_PY" "$@"
fi

# Installed venv (end-user path)
VENV_PY="$HOME/.krasis/venv/bin/python"
if [[ -x "$VENV_PY" ]]; then
    exec_repo_launcher "$VENV_PY" "$@"
fi

# Fallback to system python
exec_repo_launcher python3 "$@"
