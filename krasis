#!/usr/bin/env bash
#
# Krasis — repo entry point.
#
# For development, use ./dev (handles build, benchmark, test, etc.)
# For end-user installs, use install.sh (creates ~/.local/bin/krasis)
#
# This script exists so you can run ./krasis from the repo directory.
# It delegates immediately to the Python launcher — no venv creation,
# no pip installs, no dependency checks. That's what ./dev and
# install.sh are for.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Use conda env if available (dev machines), else system python
CONDA_PY="$HOME/miniconda3/envs/ktransformers/bin/python"
if [[ -x "$CONDA_PY" ]]; then
    exec "$CONDA_PY" -m krasis.launcher "$@"
fi

# Installed venv (end-user path)
VENV_PY="$HOME/.krasis/venv/bin/python"
if [[ -x "$VENV_PY" ]]; then
    exec "$VENV_PY" -m krasis.launcher "$@"
fi

# Fallback to system python
exec python3 -m krasis.launcher "$@"
