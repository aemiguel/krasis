do_test_kernels() {
    info "Running CUDA kernel unit tests..."
    # First ensure test data exists
    local test_data_dir="$SCRIPT_DIR/tests/kernel_test_data"
    if [[ ! -d "$test_data_dir" ]] || [[ -z "$(ls -A "$test_data_dir" 2>/dev/null)" ]]; then
        info "Generating kernel test data..."
        cd "$SCRIPT_DIR" && "$PYTHON" tests/generate_kernel_test_data.py
    fi

    # PyO3 extension modules need Python library for test linking.
    # Get the python lib dir from the conda env Python.
    local pyver
    pyver=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
    local pylibdir
    pylibdir=$("$PYTHON" -c "import sysconfig; print(sysconfig.get_config_var('LIBDIR'))")
    export PYO3_PYTHON="$PYTHON"
    export LD_LIBRARY_PATH="$pylibdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    # Tell the linker where to find libpython and to link it
    export RUSTFLAGS="${RUSTFLAGS:-} -L $pylibdir -l python${pyver}"

    # Build and run kernel tests (lib only, skip other test binaries)
    cd "$SCRIPT_DIR"
    if [[ $# -gt 0 ]]; then
        local filter="kernel_tests::test_$1"
        info "Filter: $filter"
        cargo test --release --lib "$filter" -- --nocapture 2>&1
    else
        cargo test --release --lib kernel_tests -- --nocapture 2>&1
    fi
}

do_kill() {
    info "Killing all krasis processes and freeing GPU memory..."

    # Kill any krasis Python processes
    local pids
    pids=$(pgrep -f 'python.*krasis\.' 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        for p in $pids; do
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  Killing PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Check for zombie processes holding GPU memory
    local zombie_pids
    zombie_pids=$(ps -eo pid,ppid,stat,args 2>/dev/null | awk '$3 ~ /Z/ && /krasis|python/ {print $1 " " $2}' || true)
    if [[ -n "$zombie_pids" ]]; then
        warn "Found zombie processes — killing their parents:"
        while read -r zpid zppid; do
            warn "  Zombie PID $zpid, killing parent PID $zppid"
            kill -9 "$zppid" 2>/dev/null || true
        done <<< "$zombie_pids"
        sleep 2
    fi

    # Kill any process using GPU memory (except desktop compositor type stuff)
    local gpu_pids
    gpu_pids=$(nvidia-smi --query-compute-apps=pid --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' || true)
    if [[ -n "$gpu_pids" ]]; then
        for p in $gpu_pids; do
            [[ -z "$p" ]] && continue
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  GPU process PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Wait up to 10s for GPU to clear
    local waited=0
    while [[ $waited -lt 10 ]]; do
        local gpu0_used gpu1_used
        gpu0_used=$(nvidia-smi --id=0 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        gpu1_used=$(nvidia-smi --id=1 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        if [[ "${gpu0_used:-9999}" -lt 500 ]] && [[ "${gpu1_used:-9999}" -lt 500 ]]; then
            ok "All GPUs clear."
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done

    # Last resort: nvidia-smi GPU reset
    warn "GPUs still not clear after 10s. Attempting nvidia-smi --gpu-reset..."
    if sudo nvidia-smi --gpu-reset 2>&1; then
        ok "GPU reset successful."
    else
        err "GPU reset failed. You may need to reboot.
  To reboot: sudo reboot"
    fi
}

do_shell() {
    exec "$PYTHON" "$@"
}

do_python() {
    exec "$PYTHON" "$@"
}

# ── Extract --timing flag ────────────────────────────────────────
# Can appear anywhere in args. Removes it and sets KRASIS_DECODE_TIMING=1.
TIMING_FLAG=false
args=()
for arg in "$@"; do
    if [[ "$arg" == "--timing" ]]; then
        TIMING_FLAG=true
    else
        args+=("$arg")
    fi
done
set -- "${args[@]}"

if $TIMING_FLAG; then
    export KRASIS_DECODE_TIMING=1
    info "Decode timing ENABLED (adds ~30-50% overhead — not for speed benchmarks)"
fi

#── Dispatch ─────────────────────────────────────────────────────────
cmd="${1:-help}"
shift || true

case "$cmd" in
    build)          do_build ;;
    run)            do_run "$@" ;;
    test)           do_test "$@" ;;
    benchmark)      do_benchmark "$@" ;;
    release-test)   do_release_test "$@" ;;
    release-test-all) do_release_test_all "$@" ;;
    perplexity)     do_perplexity "$@" ;;
    awq-calibrate)  do_awq_calibrate "$@" ;;
    network)        do_network "$@" ;;
    test-kernels)   do_test_kernels "$@" ;;
    shell)          do_shell "$@" ;;
    python)         do_python "$@" ;;
    help|-h|--help)
        echo "Krasis dev helper"
        echo ""
        echo "Usage: ./dev <command> [args...]"
        echo ""
        echo "Commands:"
        echo "  build                     Rebuild Rust extension"
        echo "  run <config> [flags]      Launch server (add --benchmark for benchmarks)"
        echo "  benchmark <config>        Run standard benchmark and exit"
        echo "  release-test <model>      Run full release test (5 configs, report)"
        echo "  release-test-all [target] Run release test on all supported models sequentially"
        echo "                            Without a target: runs all, no state saved."
        echo "                            With a target (e.g. 'rc8'): saves progress to state file."
        echo "                            Re-run with same target to resume from failed model."
        echo "                            State file auto-deleted when all models pass."
        echo "                            Sends Session messages on start/pass/fail per model."
        echo "  perplexity <config>       Run perplexity eval (WikiText-2) and exit"
        echo "  awq-calibrate <config>    Run AWQ attention calibration (produces template)"
        echo "  test <config>             Short model test (benchmark + network tests)"
        echo "  test <config> --thorough  Thorough test (+ stress + large prompts)"
        echo "  network <port> [flags]    Run network tests against running server"
        echo "  test-kernels [name]       Run CUDA kernel unit tests (or filter by name)"
        echo "  chat [args]               Run krasis chat from source"
        echo "  sanity                    Run sanity test prompts against running server"
        echo "  kill                      Kill all krasis/GPU processes, reset if needed"
        echo "  install                   Sync krasis command to ~/.local/bin (uses source)"
        echo "  shell                     Python shell with dev env"
        echo "  python <args>             Run Python with dev env"
        echo ""
        echo "Global flags:"
        echo "  --timing    Enable per-component decode timing (adds ~30-50% overhead)"
        echo "              Prints detailed breakdown of where decode time is spent."
        echo "              NOT for speed benchmarks — only for profiling."
        echo ""
        echo "Configs: qcn, qcn-a4, q235, q235-a4, v2lite, deepseek-vl, qwen35, qwen35-a4"
        echo "         (or path to .conf file)"
        echo ""
        echo "Examples:"
        echo "  ./dev build"
        echo "  ./dev run qcn"
        echo "  ./dev run qcn --benchmark"
        echo "  ./dev benchmark qcn --timing    Profile decode components"
        echo "  ./dev benchmark qcn             Normal speed benchmark"
        echo "  ./dev release-test Qwen3-Coder-Next    Full release test"
        echo "  ./dev release-test-all                 Test all models (no resume)"
        echo "  ./dev release-test-all rc8             Test all models (resume on re-run with same target)"
        echo "  ./dev awq-calibrate qcn    Build AWQ attention template"
        echo "  ./dev perplexity qcn"
        echo "  ./dev test qcn"
        echo "  ./dev network 8012"
        echo "  ./dev python -m krasis.launcher"
        ;;
    kill)       do_kill ;;
    chat)       exec "$PYTHON" -m krasis.chat "$@" ;;
    sanity)     exec "$PYTHON" -m krasis.chat --sanitytest "$@" ;;
    install)
        info "Installing krasis command to ~/.local/bin/krasis..."
        mkdir -p "$HOME/.local/bin"
        # Symlink so installed command is always identical to repo script
        rm -f "$HOME/.local/bin/krasis"
        ln -s "$SCRIPT_DIR/krasis" "$HOME/.local/bin/krasis"
