do_test_kernels() {
    info "Running CUDA kernel unit tests..."
    # First ensure test data exists
    local test_data_dir="$SCRIPT_DIR/tests/kernel_test_data"
    if [[ ! -d "$test_data_dir" ]] || [[ -z "$(ls -A "$test_data_dir" 2>/dev/null)" ]]; then
        info "Generating kernel test data..."
        cd "$SCRIPT_DIR" && run_repo_python tests/generate_kernel_test_data.py
    fi

    # PyO3 extension modules need Python library for test linking.
    # Get the python lib dir from the conda env Python.
    local pyver
    pyver=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
    local pylibdir
    pylibdir=$("$PYTHON" -c "import sysconfig; print(sysconfig.get_config_var('LIBDIR'))")
    export PYO3_PYTHON="$PYTHON"
    export LD_LIBRARY_PATH="$pylibdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    # Tell the linker where to find libpython and to link it
    export RUSTFLAGS="${RUSTFLAGS:-} -L $pylibdir -l python${pyver}"

    # Build and run kernel tests (lib only, skip other test binaries)
    cd "$SCRIPT_DIR"
    if [[ $# -gt 0 ]]; then
        local filter="kernel_tests::test_$1"
        info "Filter: $filter"
        cargo test --release --lib "$filter" -- --nocapture 2>&1
    else
        cargo test --release --lib kernel_tests -- --nocapture 2>&1
    fi
}

