    case "$path" in
        /home/*/*)
            local remainder="${path#/home/}"
            local user="${remainder%%/*}"
            [[ -n "$user" ]] && echo "/home/$user"
            ;;
        /Users/*/*)
            local remainder="${path#/Users/}"
            local user="${remainder%%/*}"
            [[ -n "$user" ]] && echo "/Users/$user"
            ;;
        *)
            return 1
            ;;
    esac
}

