do_kill() {
    info "Killing all krasis processes and freeing GPU memory..."

    # Kill any krasis Python processes
    local pids
    pids=$(pgrep -f 'python.*krasis\.' 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        for p in $pids; do
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  Killing PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Check for zombie processes holding GPU memory
    local zombie_pids
    zombie_pids=$(ps -eo pid,ppid,stat,args 2>/dev/null | awk '$3 ~ /Z/ && /krasis|python/ {print $1 " " $2}' || true)
    if [[ -n "$zombie_pids" ]]; then
        warn "Found zombie processes — killing their parents:"
        while read -r zpid zppid; do
            warn "  Zombie PID $zpid, killing parent PID $zppid"
            kill -9 "$zppid" 2>/dev/null || true
        done <<< "$zombie_pids"
        sleep 2
    fi

    # Kill any process using GPU memory (except desktop compositor type stuff)
    local gpu_pids
    gpu_pids=$(nvidia-smi --query-compute-apps=pid --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' || true)
    if [[ -n "$gpu_pids" ]]; then
        for p in $gpu_pids; do
            [[ -z "$p" ]] && continue
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  GPU process PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Wait up to 10s for GPU to clear
    local waited=0
    while [[ $waited -lt 10 ]]; do
        local gpu0_used gpu1_used
        gpu0_used=$(nvidia-smi --id=0 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        gpu1_used=$(nvidia-smi --id=1 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        if [[ "${gpu0_used:-9999}" -lt 500 ]] && [[ "${gpu1_used:-9999}" -lt 500 ]]; then
            ok "All GPUs clear."
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done

    # Last resort: nvidia-smi GPU reset
    warn "GPUs still not clear after 10s. Attempting nvidia-smi --gpu-reset..."
    if sudo nvidia-smi --gpu-reset 2>&1; then
        ok "GPU reset successful."
    else
        err "GPU reset failed. You may need to reboot.
  To reboot: sudo reboot"
    fi
}

