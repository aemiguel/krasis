#!/usr/bin/env bash
#
# Krasis dev helper — single entry point for build, run, test, benchmark.
#
# Usage:
#   ./dev build                     Rebuild Rust extension into the dev env
#   ./dev run <config>              Launch server from a test config
#   ./dev run <config> --benchmark  Launch with benchmark, then serve
#   ./dev test <config>             Run short model test (benchmark + network tests)
#   ./dev test <config> --thorough  Run thorough model test (stress + benchmark + network + large)
#   ./dev network <port>            Run network tests against a running server
#   ./dev network <port> --large    Include large-prompt tests
#   ./dev benchmark <config>        Run standard benchmark (prefill/decode/round trip) and exit
#   ./dev perplexity <config>       Run perplexity eval (WikiText-2 by default) and exit
#   ./dev release-test <model>      Run full release test (4 configs, produces report)
#   ./dev awq-calibrate <config>    Run AWQ calibration, produce attention template
#   ./dev kill                      Kill all krasis processes and free GPU memory
#   ./dev shell                     Drop into a Python shell with the dev env
#   ./dev python <args...>          Run arbitrary Python with the dev env
#
# Timing / profiling:
#   Add --timing to any command to enable per-component decode timing.
#   This inserts GPU synchronization barriers between each decode phase and
#   prints a detailed timing breakdown at the end. Adds ~30-50% overhead so
#   do NOT use for speed benchmarks — only for understanding where time goes.
#
#   Examples:
#     ./dev benchmark qcn --timing    Profile decode components
#     ./dev run qcn --timing          Run server with timing enabled
#     ./dev benchmark qcn             Normal speed benchmark (no timing overhead)
#
# Configs are short names that map to testconfigs/*.conf:
#   qcn         -> testconfigs/qcn-4-4-a16.conf
#   qcn-a4      -> testconfigs/qcn-4-4-a4.conf
#   q235        -> testconfigs/q235-4-4-a16.conf
#   q235-a4     -> testconfigs/q235-4-4-a4.conf
#   v2lite      -> testconfigs/v2lite-4-4-a16.conf
#   deepseek-vl -> testconfigs/deepseek-vl2-4-4-a16.conf
#   qwen35      -> testconfigs/qwen35-4-4-a16.conf
#   qwen35-a4   -> testconfigs/qwen35-4-4-a4.conf
#
set -euo pipefail

# ── Environment ──────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON="/home/main/miniconda3/envs/ktransformers/bin/python"
export PYTHONUNBUFFERED=1
PIP="/home/main/miniconda3/envs/ktransformers/bin/pip"
MATURIN="/home/main/.local/bin/maturin"
SO_FILE="$SCRIPT_DIR/python/krasis/krasis.cpython-311-x86_64-linux-gnu.so"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

info()  { echo -e "${CYAN}${BOLD}=>${NC} $*"; }
ok()    { echo -e "${GREEN}${BOLD}OK${NC} $*"; }
warn()  { echo -e "${YELLOW}${BOLD}!!${NC} $*"; }
err()   { echo -e "${RED}${BOLD}ERROR${NC} $*" >&2; exit 1; }

# ── Sanity checks ────────────────────────────────────────────────────
[[ -f "$PYTHON" ]] || err "Python not found at $PYTHON
  See DEV.md for environment setup instructions."

[[ -f "$MATURIN" ]] || err "maturin not found at $MATURIN
  Install: pip install maturin"

# ── Config resolver ──────────────────────────────────────────────────
resolve_config() {
    local name="$1"
    case "$name" in
        qcn|QCN)            echo "$SCRIPT_DIR/testconfigs/qcn-4-4-a16.conf" ;;
        qcn-a4)             echo "$SCRIPT_DIR/testconfigs/qcn-4-4-a4.conf" ;;
        q235)               echo "$SCRIPT_DIR/testconfigs/q235-4-4-a16.conf" ;;
        q235-a4)            echo "$SCRIPT_DIR/testconfigs/q235-4-4-a4.conf" ;;
        v2lite|V2-Lite)     echo "$SCRIPT_DIR/testconfigs/v2lite-4-4-a16.conf" ;;
        deepseek-vl|vl2)    echo "$SCRIPT_DIR/testconfigs/deepseek-vl2-4-4-a16.conf" ;;
        qwen35|Qwen3.5)     echo "$SCRIPT_DIR/testconfigs/qwen35-4-4-a16.conf" ;;
        qwen35-a4)          echo "$SCRIPT_DIR/testconfigs/qwen35-4-4-a4.conf" ;;
        *)
            # Try as a direct path
            if [[ -f "$name" ]]; then
                echo "$name"
            elif [[ -f "$SCRIPT_DIR/testconfigs/$name" ]]; then
                echo "$SCRIPT_DIR/testconfigs/$name"
            else
                err "Unknown config: $name
  Available: qcn, qcn-a4, q235, q235-a4, v2lite, deepseek-vl, qwen35, qwen35-a4
  Or pass a path to a .conf file."
            fi
            ;;
    esac
}

# No need for conf_to_args — server.py has native --config support

# Extract port from a .conf file
conf_port() {
    local conf="$1"
    grep '^CFG_PORT=' "$conf" | head -1 | cut -d'"' -f2
}

# ── Auto-rebuild check ──────────────────────────────────────────────
needs_rebuild() {
    # If .so doesn't exist, definitely need to build
    [[ ! -f "$SO_FILE" ]] && return 0

    local so_mtime
    so_mtime=$(stat --format="%Y" "$SO_FILE" 2>/dev/null) || return 0

    # Check if any Rust source or Cargo files are newer than the .so
    while IFS= read -r -d '' f; do
        local f_mtime
        f_mtime=$(stat --format="%Y" "$f" 2>/dev/null) || continue
        if [[ "$f_mtime" -gt "$so_mtime" ]]; then
            return 0
        fi
    done < <(find "$SCRIPT_DIR/src" -name "*.rs" -print0 2>/dev/null)

    # Check Cargo.toml and build.rs
    for f in "$SCRIPT_DIR/Cargo.toml" "$SCRIPT_DIR/build.rs"; do
        if [[ -f "$f" ]]; then
            local f_mtime
            f_mtime=$(stat --format="%Y" "$f" 2>/dev/null) || continue
            if [[ "$f_mtime" -gt "$so_mtime" ]]; then
                return 0
            fi
        fi
    done

    return 1
}

auto_rebuild() {
    if needs_rebuild; then
        warn "Rust source is newer than compiled extension. Rebuilding..."
        do_build
    fi
}

# ── GPU cleanup ─────────────────────────────────────────────────────
# Kill any existing krasis processes and wait for GPUs to be fully clear.
# Called before every run/test to prevent OOMs from stale processes.

cleanup_gpu() {
    # Find all krasis server/stress/benchmark Python processes (but not this script)
    local pids
    pids=$(pgrep -f 'python.*krasis\.' 2>/dev/null || true)

    if [[ -n "$pids" ]]; then
        warn "Found existing krasis processes — killing them:"
        for p in $pids; do
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  PID $p: $cmdline"
        done

        # SIGTERM first
        for p in $pids; do
            kill -TERM "$p" 2>/dev/null || true
        done

        # Wait up to 10s for graceful exit
        local waited=0
        while [[ $waited -lt 10 ]]; do
            local still_alive=false
            for p in $pids; do
                if kill -0 "$p" 2>/dev/null; then
                    still_alive=true
                    break
                fi
            done
            $still_alive || break
            sleep 1
            waited=$((waited + 1))
        done

        # SIGKILL any survivors
        for p in $pids; do
            if kill -0 "$p" 2>/dev/null; then
                warn "  PID $p still alive after SIGTERM, sending SIGKILL"
                kill -9 "$p" 2>/dev/null || true
            fi
        done

        # Wait for SIGKILL to take effect
        sleep 2
        for p in $pids; do
            wait "$p" 2>/dev/null || true
        done
    fi

    # Now wait for GPU memory to actually be released.
    # CUDA memory isn't freed until the process fully exits.
    info "Waiting for GPU memory to clear..."
    local gpu_timeout=30
    local gpu_waited=0
    while [[ $gpu_waited -lt $gpu_timeout ]]; do
        local all_clear=true
        while IFS=', ' read -r idx used total; do
            # Baseline is ~200-300 MiB (desktop compositor). 500 MiB threshold.
            if [[ "$used" -gt 500 ]]; then
                all_clear=false
                break
            fi
        done < <(nvidia-smi --query-gpu=index,memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null)

        if $all_clear; then
            ok "All GPUs clear."
            return 0
        fi

        sleep 1
        gpu_waited=$((gpu_waited + 1))
    done

    # If we get here, GPUs didn't clear. Show what's using them.
    warn "GPUs still not clear after ${gpu_timeout}s:"
    nvidia-smi 2>/dev/null || true
    err "Cannot proceed — GPU memory not released. Check for non-krasis processes using the GPU."
}

# ── Commands ─────────────────────────────────────────────────────────

do_build() {
    info "Building Rust extension (maturin develop --release)..."
    cd "$SCRIPT_DIR"
    VIRTUAL_ENV="$(dirname "$(dirname "$PYTHON")")" PATH="$HOME/.cargo/bin:$(dirname "$PYTHON"):$PATH" \
        "$MATURIN" develop --release 2>&1
    ok "Build complete. Extension at: $SO_FILE"
}

do_run() {
    [[ $# -lt 1 ]] && err "Usage: ./dev run <config> [--benchmark] [extra args...]"
    local conf
    conf=$(resolve_config "$1")
    shift
    cleanup_gpu
    auto_rebuild
    info "Launching from: $conf"
    exec "$PYTHON" -m krasis.server --config "$conf" "$@"
}

do_test() {
    [[ $# -lt 1 ]] && err "Usage: ./dev test <config> [--thorough]"
    local conf
    conf=$(resolve_config "$1")
    local thorough=false
    [[ "${2:-}" == "--thorough" ]] && thorough=true
    cleanup_gpu
    auto_rebuild

    local port
    port=$(conf_port "$conf")
    [[ -z "$port" ]] && port=8012

    info "=== Short Model Test ==="
    info "Config: $conf"
    info "Port: $port"

    # Step 1: Launch server with benchmark
    info "Step 1: Launching server with --benchmark..."
    local logfile
    mkdir -p "$SCRIPT_DIR/logs/tests"
    logfile="$SCRIPT_DIR/logs/tests/krasis_test_$(basename "$conf" .conf)_$(date +%Y%m%d_%H%M%S).log"
    info "Log: $logfile"

    "$PYTHON" -m krasis.server --config "$conf" --benchmark > >(tee "$logfile") 2>&1 &
    local pid=$!

    # Wait for benchmark to complete AND server to be ready.
    # Must wait for BENCHMARK COMPLETE, not just "Server ready", because
    # the benchmark runs on a separate thread. Sending HTTP requests while
    # the benchmark is still using the GPU causes CUDA_ERROR_ILLEGAL_ADDRESS.
    local ready=false
    local timeout=1200  # 20 minutes for model load + benchmark
    local elapsed=0
    while kill -0 "$pid" 2>/dev/null && [[ $elapsed -lt $timeout ]]; do
        if grep -q "BENCHMARK COMPLETE" "$logfile" 2>/dev/null; then
            ready=true
            break
        fi
        sleep 2
        elapsed=$((elapsed + 2))
    done

    if ! $ready; then
        if kill -0 "$pid" 2>/dev/null; then
            warn "Timed out waiting for server (${timeout}s). Killing..."
            kill -TERM "$pid" 2>/dev/null || true
            sleep 2
            kill -9 "$pid" 2>/dev/null || true
        fi
        err "Server did not start. Check log: $logfile"
    fi

    ok "Server is ready. Benchmark results are in the log."

    # Step 2: Run network multi-prompt tests
    info "Step 2: Running network multi-prompt tests..."
    if $thorough; then
        "$PYTHON" "$SCRIPT_DIR/tests/test_network.py" --port "$port" --large 2>&1 | tee -a "$logfile"
    else
        "$PYTHON" "$SCRIPT_DIR/tests/test_network.py" --port "$port" 2>&1 | tee -a "$logfile"
    fi

    local net_result=$?

    # Cleanup: kill the server
    info "Stopping server..."
    kill -TERM "$pid" 2>/dev/null || true
    sleep 2
    kill -9 "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true

    echo ""
    if [[ $net_result -eq 0 ]]; then
        ok "=== All tests PASSED ==="
    else
        err "Network tests FAILED (exit code $net_result)"
    fi
    info "Full log: $logfile"
}

do_release_test() {
    [[ $# -lt 1 ]] && err "Usage: ./dev release-test <model> [--force-rebuild-cache]
  model = directory name under ~/.krasis/models/
  Example: ./dev release-test Qwen3-Coder-Next"
    local model="$1"
    shift
    cleanup_gpu
    info "Starting release test for model: $model"
    KRASIS_DEV_SCRIPT=1 "$PYTHON" "$SCRIPT_DIR/tests/release_test.py" "$model" "$@"
}

do_benchmark() {
    [[ $# -lt 1 ]] && err "Usage: ./dev benchmark <config>"
    local conf
    conf=$(resolve_config "$1")
    cleanup_gpu
    auto_rebuild
    local logfile
    logfile="$SCRIPT_DIR/logs/benchmarks/krasis_benchmark_$(basename "$conf" .conf)_$(date +%Y%m%d_%H%M%S).log"
    mkdir -p "$SCRIPT_DIR/logs/benchmarks"
    info "Running standard benchmark: $conf"
    info "Log: $logfile"
    "$PYTHON" -m krasis.server --config "$conf" --benchmark-only 2>&1 | tee "$logfile"
    info "Benchmark log saved: $logfile"
}

do_perplexity() {
    [[ $# -lt 1 ]] && err "Usage: ./dev perplexity <config> [--dataset wikitext-2] [--max-tokens N]"
    local conf
    conf=$(resolve_config "$1")
    shift
    cleanup_gpu
    auto_rebuild
    local logfile
    logfile="$SCRIPT_DIR/logs/perplexity/krasis_perplexity_$(basename "$conf" .conf)_$(date +%Y%m%d_%H%M%S).log"
    mkdir -p "$SCRIPT_DIR/logs/perplexity"
    info "Running perplexity: $conf"
    info "Log: $logfile"
    cd "$SCRIPT_DIR" && "$PYTHON" -m perplexity.measure_ppl --config "$conf" "$@" 2>&1 | tee "$logfile"
    info "Perplexity log saved: $logfile"
}

do_awq_calibrate() {
    [[ $# -lt 1 ]] && err "Usage: ./dev awq-calibrate <config> [--tokens 256000] [--dataset wikitext-2]"
    local conf
    conf=$(resolve_config "$1")
    shift
    cleanup_gpu
    auto_rebuild
    info "Running AWQ calibration: $conf"
    cd "$SCRIPT_DIR" && "$PYTHON" -m krasis.awq_calibrate --config "$conf" "$@"
}

do_network() {
    [[ $# -lt 1 ]] && err "Usage: ./dev network <port> [--large] [--quick]"
    local port="$1"
    shift
    exec "$PYTHON" "$SCRIPT_DIR/tests/test_network.py" --port "$port" "$@"
}

do_kill() {
    info "Killing all krasis processes and freeing GPU memory..."

    # Kill any krasis Python processes
    local pids
    pids=$(pgrep -f 'python.*krasis\.' 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        for p in $pids; do
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  Killing PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Check for zombie processes holding GPU memory
    local zombie_pids
    zombie_pids=$(ps -eo pid,ppid,stat,args 2>/dev/null | awk '$3 ~ /Z/ && /krasis|python/ {print $1 " " $2}' || true)
    if [[ -n "$zombie_pids" ]]; then
        warn "Found zombie processes — killing their parents:"
        while read -r zpid zppid; do
            warn "  Zombie PID $zpid, killing parent PID $zppid"
            kill -9 "$zppid" 2>/dev/null || true
        done <<< "$zombie_pids"
        sleep 2
    fi

    # Kill any process using GPU memory (except desktop compositor type stuff)
    local gpu_pids
    gpu_pids=$(nvidia-smi --query-compute-apps=pid --format=csv,noheader,nounits 2>/dev/null | tr -d ' ' || true)
    if [[ -n "$gpu_pids" ]]; then
        for p in $gpu_pids; do
            [[ -z "$p" ]] && continue
            local cmdline
            cmdline=$(ps -p "$p" -o args= 2>/dev/null || echo "unknown")
            warn "  GPU process PID $p: $cmdline"
            kill -9 "$p" 2>/dev/null || true
        done
        sleep 2
    fi

    # Wait up to 10s for GPU to clear
    local waited=0
    while [[ $waited -lt 10 ]]; do
        local gpu0_used gpu1_used
        gpu0_used=$(nvidia-smi --id=0 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        gpu1_used=$(nvidia-smi --id=1 --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
        if [[ "${gpu0_used:-9999}" -lt 500 ]] && [[ "${gpu1_used:-9999}" -lt 500 ]]; then
            ok "All GPUs clear."
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done

    # Last resort: nvidia-smi GPU reset
    warn "GPUs still not clear after 10s. Attempting nvidia-smi --gpu-reset..."
    if sudo nvidia-smi --gpu-reset 2>&1; then
        ok "GPU reset successful."
    else
        err "GPU reset failed. You may need to reboot.
  To reboot: sudo reboot"
    fi
}

do_shell() {
    exec "$PYTHON" "$@"
}

do_python() {
    exec "$PYTHON" "$@"
}

# ── Extract --timing flag ────────────────────────────────────────
# Can appear anywhere in args. Removes it and sets KRASIS_DECODE_TIMING=1.
TIMING_FLAG=false
args=()
for arg in "$@"; do
    if [[ "$arg" == "--timing" ]]; then
        TIMING_FLAG=true
    else
        args+=("$arg")
    fi
done
set -- "${args[@]}"

if $TIMING_FLAG; then
    export KRASIS_DECODE_TIMING=1
    info "Decode timing ENABLED (adds ~30-50% overhead — not for speed benchmarks)"
fi

#── Dispatch ─────────────────────────────────────────────────────────
cmd="${1:-help}"
shift || true

case "$cmd" in
    build)          do_build ;;
    run)            do_run "$@" ;;
    test)           do_test "$@" ;;
    benchmark)      do_benchmark "$@" ;;
    release-test)   do_release_test "$@" ;;
    perplexity)     do_perplexity "$@" ;;
    awq-calibrate)  do_awq_calibrate "$@" ;;
    network)        do_network "$@" ;;
    shell)          do_shell "$@" ;;
    python)         do_python "$@" ;;
    help|-h|--help)
        echo "Krasis dev helper"
        echo ""
        echo "Usage: ./dev <command> [args...]"
        echo ""
        echo "Commands:"
        echo "  build                     Rebuild Rust extension"
        echo "  run <config> [flags]      Launch server (add --benchmark for benchmarks)"
        echo "  benchmark <config>        Run standard benchmark and exit"
        echo "  release-test <model>      Run full release test (4 configs, report)"
        echo "  perplexity <config>       Run perplexity eval (WikiText-2) and exit"
        echo "  awq-calibrate <config>    Run AWQ attention calibration (produces template)"
        echo "  test <config>             Short model test (benchmark + network tests)"
        echo "  test <config> --thorough  Thorough test (+ stress + large prompts)"
        echo "  network <port> [flags]    Run network tests against running server"
        echo "  kill                      Kill all krasis/GPU processes, reset if needed"
        echo "  shell                     Python shell with dev env"
        echo "  python <args>             Run Python with dev env"
        echo ""
        echo "Global flags:"
        echo "  --timing    Enable per-component decode timing (adds ~30-50% overhead)"
        echo "              Prints detailed breakdown of where decode time is spent."
        echo "              NOT for speed benchmarks — only for profiling."
        echo ""
        echo "Configs: qcn, qcn-a4, q235, q235-a4, v2lite, deepseek-vl, qwen35, qwen35-a4"
        echo "         (or path to .conf file)"
        echo ""
        echo "Examples:"
        echo "  ./dev build"
        echo "  ./dev run qcn"
        echo "  ./dev run qcn --benchmark"
        echo "  ./dev benchmark qcn --timing    Profile decode components"
        echo "  ./dev benchmark qcn             Normal speed benchmark"
        echo "  ./dev release-test Qwen3-Coder-Next    Full release test"
        echo "  ./dev awq-calibrate qcn    Build AWQ attention template"
        echo "  ./dev perplexity qcn"
        echo "  ./dev test qcn"
        echo "  ./dev network 8012"
        echo "  ./dev python -m krasis.launcher"
        ;;
    kill)       do_kill ;;
    *)
        err "Unknown command: $cmd
  Run ./dev help for usage."
        ;;
esac
