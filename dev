        echo "  ./dev capture-box generate Qwen3-Coder-Next --profile greedy_chat_thinking_off"
        echo "  ./dev reference-backfill-topk qwen35 --reference ../krasis-internal/reference-outputs/output/Qwen3.5-35B-A3B/greedy_reference.json"
        echo "  ./dev awq-calibrate qcn    Build AWQ attention template"
        echo "  ./dev perplexity qcn"
        echo "  ./dev trace-diff /tmp/expected.log /tmp/actual.log --events mark,tensor"
        echo "  ./dev trace-diff /tmp/expected.log /tmp/actual.log --components config_contract --contexts reference_inventory --show-window 3"
        echo "  ./dev trace-diff /tmp/expected.log /tmp/actual.log --components decode --resync-window 6"
        echo "  ./dev trace-diff /tmp/expected.log /tmp/actual.log --components decode --family-resync-window 3"
        echo "  ./dev test qcn"
        echo "  ./dev network 8012"
        echo "  ./dev python -m krasis.launcher"
        ;;
    kill)       do_kill ;;
    chat)       verify_repo_imports; exec_repo_python -m krasis.chat "$@" ;;
    sanity)
        verify_repo_imports
        run_dir=$(create_run_dir "dev-sanity")
        info "Run dir: $run_dir"
        KRASIS_RUN_DIR="$run_dir" KRASIS_RUN_TYPE="dev-sanity" exec_repo_python -m krasis.chat --sanitytest "$@"
        ;;
    install)
        info "Installing krasis command to ~/.local/bin/krasis..."
        mkdir -p "$HOME/.local/bin"
        # Symlink so installed command is always identical to repo script
        rm -f "$HOME/.local/bin/krasis"
        ln -s "$SCRIPT_DIR/krasis" "$HOME/.local/bin/krasis"
        # Clean up any stale pip/venv artifacts
        rm -f "$HOME/.local/bin/krasis-chat" "$HOME/.local/bin/krasis-setup"
        rm -rf "$HOME/.krasis/venv"
        ok "Installed. 'krasis' command symlinked to $SCRIPT_DIR/krasis"
        ;;
    *)
        err "Unknown command: $cmd
  Run ./dev help for usage."
        ;;
esac
