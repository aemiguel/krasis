do_capture_box() {
    local subcmd="${1:-help}"
    shift || true
    enter_capture_box_env

    case "$subcmd" in
        env)
            print_capture_box_env "$KRASIS_CAPTURE_BOX_REPO_HOME"
            ;;
        preflight|capture-preflight)
            print_capture_box_env "$KRASIS_CAPTURE_BOX_REPO_HOME"
            do_capture_preflight "$@"
            ;;
        prep|reference-prep)
            print_capture_box_env "$KRASIS_CAPTURE_BOX_REPO_HOME"
            do_reference_prep "$@"
            ;;
        stage)
            local dry_run=0
            local skip_bootstrap=0
            local -a stage_models=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run)
                        dry_run=1
                        shift
                        ;;
                    --no-bootstrap)
                        skip_bootstrap=1
                        shift
                        ;;
                    -h|--help)
                        echo "Usage: ./dev capture-box stage [--dry-run] [--no-bootstrap] <model> [more models...]"
                        echo ""
                        echo "Bootstrap the paid-box capture host once, then queue one or more model"
                        echo "downloads through the enforced capture-box environment."
                        echo ""
                        echo "Options:"
                        echo "  --dry-run       Print the exact staged commands without running them"
                        echo "  --no-bootstrap  Skip capture-preflight --bootstrap and assume the host is already ready"
                        echo ""
                        echo "Example:"
                        echo "  ./dev capture-box stage qcn gemma"
                        echo "  ./dev capture-box stage --dry-run qcn gemma"
                        return 0
                        ;;
                    -*)
                        err "Unknown capture-box stage option: $1"
                        ;;
                    *)
                        stage_models+=("$1")
                        shift
                        ;;
                esac
            done
            [[ "${#stage_models[@]}" -gt 0 ]] || err "Usage: ./dev capture-box stage [--dry-run] [--no-bootstrap] <model> [more models...]"
            print_capture_box_env "$KRASIS_CAPTURE_BOX_REPO_HOME"
            if [[ "$skip_bootstrap" -eq 0 ]]; then
                info "Stage bootstrap target: ${stage_models[0]}"
                if [[ "$dry_run" -eq 1 ]]; then
                    local bootstrap_cmd
                    printf -v bootstrap_cmd '%q ' ./dev capture-box preflight --bootstrap --model "${stage_models[0]}"
                    echo "DRY RUN: ${bootstrap_cmd% }"
                else
                    do_capture_preflight --bootstrap --model "${stage_models[0]}"
                fi
            else
                warn "Skipping capture bootstrap as requested"
            fi
            local model
            for model in "${stage_models[@]}"; do
                info "Queueing staged model: $model"
                if [[ "$dry_run" -eq 1 ]]; then
                    local prep_cmd
                    printf -v prep_cmd '%q ' ./dev capture-box prep "$model" --detach
                    echo "DRY RUN: ${prep_cmd% }"
                else
                    do_reference_prep "$model" --detach
                fi
            done
            if [[ "$dry_run" -eq 1 ]]; then
                info "Dry run complete"
            else
                ok "Staged ${#stage_models[@]} model download(s)"
                echo "Next: run ./dev capture-box generate <model> --profile <profile> once the first model is ready."
            fi
            ;;
        generate|generate-reference)
            print_capture_box_env "$KRASIS_CAPTURE_BOX_REPO_HOME"
            [[ $# -ge 1 ]] || err "Usage: ./dev capture-box generate <model> [--profile PROFILE] [--max-tokens N] [--conversation-index N [--turn-index N|--turn-start-index N --turn-end-index N]] [--attn-implementation eager|sdpa|flash_attention_2]"
            info "Verifying paid-box capture host for model: $1"
            do_capture_preflight --bootstrap --model "$1"
            do_generate_reference "$@"
            ;;
        help|-h|--help)
            echo "Usage: ./dev capture-box <subcommand> [args...]"
            echo ""
            echo "ARCHIVED strict paid-box wrapper for HF capture work."
            echo "HF/Transformers capture commands now require KRASIS_ALLOW_ARCHIVED_HF_REFERENCE=1."
            echo ""
            echo "Historical behavior:"
            echo "It enforces one remote identity before any expensive work:"
            echo "  - HOME := inferred repo owner home"
            echo "  - PATH prepends <repo-home>/.cargo/bin"
            echo "  - capture root := <repo-home>/.krasis"
            echo "  - capture root source := capture_box"
            echo ""
            echo "Subcommands:"
            echo "  env                            Print the enforced environment and exit"
            echo "  preflight [args...]            Run ./dev capture-preflight under the enforced environment"
            echo "  prep [args...]                 Run ./dev reference-prep under the enforced environment"
            echo "  stage [args...]                Bootstrap once, then queue one or more model downloads"
            echo "  generate [args...]             Run ./dev generate-reference under the enforced environment"
            echo ""
            echo "Examples:"
            echo "  ./dev capture-box env"
            echo "  ./dev capture-box preflight --bootstrap --model qcn"
            echo "  ./dev capture-box prep qcn --detach"
            echo "  ./dev capture-box stage qcn gemma"
            echo "  ./dev capture-box generate Qwen3-Coder-Next --profile greedy_chat_thinking_off"
            ;;
        *)
            err "Unknown capture-box subcommand: $subcmd
  Expected one of: env, preflight, prep, stage, generate"
            ;;
    esac
}

