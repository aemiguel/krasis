do_witness_gguf_preflight() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        echo "Usage: ./dev witness-gguf-preflight <model> [--output PATH] [--outtype bf16]"
        echo "  Preflights BF16 GGUF witness conversion without starting conversion."
        echo "  Records source files, expected output, resource estimates, converter command, and support gates."
        echo "  Models: qwen35"
        return 0
    fi
    [[ $# -lt 1 ]] && err "Usage: ./dev witness-gguf-preflight <model> [--output PATH] [--outtype bf16]"
    local model="$1"
    shift
    local output_override=""
    local outtype="bf16"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)
                [[ $# -ge 2 ]] || err "--output requires a path"
                output_override="$2"
                shift 2
                ;;
            --outtype)
                [[ $# -ge 2 ]] || err "--outtype requires a value"
                outtype="$2"
                shift 2
                ;;
            --help|-h)
                echo "Usage: ./dev witness-gguf-preflight <model> [--output PATH] [--outtype bf16]"
                echo "  Preflights BF16 GGUF witness conversion without starting conversion."
                echo "  Models: qwen35"
                return 0
                ;;
            *)
                err "Unknown witness-gguf-preflight argument: $1"
                ;;
        esac
    done
    [[ "$outtype" == "bf16" ]] || err "Only --outtype bf16 is accepted for witness authority preflight"
    [[ -d "$WITNESS_REPO" ]] || err "llama-witness repo not found: $WITNESS_REPO"

    mapfile -t paths < <(witness_model_paths "$model")
    local model_dir="${paths[0]}"
    local default_reference_json="${paths[1]}"
    local expected_gguf="${paths[2]}"
    [[ -n "$output_override" ]] && expected_gguf="$output_override"

    local run_dir report
    run_dir=$(create_run_dir "witness-gguf-preflight")
    report="$run_dir/witness_gguf_preflight.json"
    info "Running BF16 GGUF witness conversion preflight"
    info "Run dir: $run_dir"
    info "Report: $report"

    local status=0
    local converter="$WITNESS_REPO/convert_hf_to_gguf.py"
    local config="$model_dir/config.json"
    local tokenizer="$model_dir/tokenizer.json"
    local tokenizer_config="$model_dir/tokenizer_config.json"
    local generation_config="$model_dir/generation_config.json"
    local index_json="$model_dir/model.safetensors.index.json"
    local arch model_type text_model_type transformers_version
    arch=""
    model_type=""
    text_model_type=""
    transformers_version=""

    if [[ -f "$config" ]]; then
        arch=$(jq -r '.architectures[0] // ""' "$config")
        model_type=$(jq -r '.model_type // ""' "$config")
        text_model_type=$(jq -r '.text_config.model_type // ""' "$config")
        transformers_version=$(jq -r '.transformers_version // ""' "$config")
    else
        status=1
    fi

    local expected_arch="Qwen3_5MoeForConditionalGeneration"
    local expected_model_type="qwen3_5_moe"
    local expected_text_model_type="qwen3_5_moe_text"
    local config_supported=false
    if [[ "$arch" == "$expected_arch" && "$model_type" == "$expected_model_type" && "$text_model_type" == "$expected_text_model_type" ]]; then
        config_supported=true
    else
        status=1
    fi

    local converter_supported=false gguf_supported=false runtime_supported=false
    if rg -q 'Qwen3_5MoeForConditionalGeneration' "$converter" \
        && rg -q 'class Qwen3_5MoeTextModel' "$converter" \
        && rg -q 'MODEL_ARCH.QWEN35MOE' "$converter"; then
        converter_supported=true
    else
        status=1
    fi
    if rg -q 'QWEN35MOE' "$WITNESS_REPO/gguf-py/gguf/constants.py"; then
        gguf_supported=true
    else
        status=1
    fi
    if rg -q 'LLM_ARCH_QWEN35MOE' "$WITNESS_REPO/src/llama-arch.h" \
        && rg -q 'llm_build_qwen35moe' "$WITNESS_REPO/src/llama-model.cpp" \
        && [[ -f "$WITNESS_REPO/src/models/qwen35moe.cpp" ]]; then
        runtime_supported=true
    else
        status=1
    fi

    local required_missing=()
    local required_file
    for required_file in "$config" "$tokenizer" "$tokenizer_config" "$generation_config" "$index_json"; do
        if [[ ! -f "$required_file" ]]; then
            required_missing+=("$required_file")
            status=1
        fi
    done

    local safetensors=()
    while IFS= read -r shard; do
        safetensors+=("$shard")
    done < <(find "$model_dir" -maxdepth 1 -type f -name '*.safetensors' | sort)
    local shard_count="${#safetensors[@]}"
    [[ "$shard_count" -gt 0 ]] || status=1
    local source_bytes
    source_bytes=$(sum_file_sizes "${safetensors[@]}" "$config" "$tokenizer" "$tokenizer_config" "$generation_config" "$index_json")

    local output_dir output_available_bytes
    output_dir="$(dirname "$expected_gguf")"
    mkdir -p "$output_dir"
    output_available_bytes=$(df -B1 --output=avail "$output_dir" | tail -n 1 | tr -d ' ')
    local ram_available_bytes
    ram_available_bytes=$(awk '/MemAvailable:/ {print $2 * 1024}' /proc/meminfo)

    # The preflight records a conservative workspace estimate; the conversion is still not started here.
    local disk_required_bytes ram_required_bytes
    disk_required_bytes=$((source_bytes * 2))
    ram_required_bytes=$((source_bytes * 3 / 2))
    local disk_sane=false ram_sane=false
    if [[ "$output_available_bytes" -ge "$disk_required_bytes" ]]; then
        disk_sane=true
    else
        status=1
    fi
    if [[ "$ram_available_bytes" -ge "$ram_required_bytes" ]]; then
        ram_sane=true
    else
        status=1
    fi

    local converter_cmd
    printf -v converter_cmd '%q ' "$PYTHON" "$converter" "$model_dir" --outtype "$outtype" --outfile "$expected_gguf"
    converter_cmd="${converter_cmd% }"

    {
        printf '{\n'
        printf '  "format": "krasis_witness_gguf_preflight",\n'
        printf '  "format_version": 1,\n'
        printf '  "model": "%s",\n' "$(json_escape "$model")"
        printf '  "outtype": "%s",\n' "$(json_escape "$outtype")"
        printf '  "source_model_path": "%s",\n' "$(json_escape "$model_dir")"
        printf '  "expected_output_path": "%s",\n' "$(json_escape "$expected_gguf")"
        printf '  "default_input_token_source": "%s",\n' "$(json_escape "$default_reference_json")"
        printf '  "converter": {\n'
        printf '    "repo": "%s",\n' "$(json_escape "$WITNESS_REPO")"
        printf '    "script": "%s",\n' "$(json_escape "$converter")"
        printf '    "outtype": "%s",\n' "$(json_escape "$outtype")"
        printf '    "command": "%s"\n' "$(json_escape "$converter_cmd")"
        printf '  },\n'
        printf '  "config": {\n'
        printf '    "architecture": "%s",\n' "$(json_escape "$arch")"
        printf '    "expected_architecture": "%s",\n' "$(json_escape "$expected_arch")"
        printf '    "model_type": "%s",\n' "$(json_escape "$model_type")"
        printf '    "expected_model_type": "%s",\n' "$(json_escape "$expected_model_type")"
        printf '    "text_model_type": "%s",\n' "$(json_escape "$text_model_type")"
        printf '    "expected_text_model_type": "%s",\n' "$(json_escape "$expected_text_model_type")"
        printf '    "transformers_version": "%s"\n' "$(json_escape "$transformers_version")"
        printf '  },\n'
        printf '  "required_files": [\n'
        local first=1
        for required_file in "$config" "$tokenizer" "$tokenizer_config" "$generation_config" "$index_json"; do
            [[ "$first" == "1" ]] || printf ',\n'
            first=0
            if [[ -f "$required_file" ]]; then
                printf '    {"path": "%s", "exists": true, "size_bytes": %s, "sha256": "%s"}' \
                    "$(json_escape "$required_file")" \
                    "$(stat -c '%s' "$required_file")" \
                    "$(sha256sum "$required_file" | awk '{print $1}')"
            else
                printf '    {"path": "%s", "exists": false}' "$(json_escape "$required_file")"
            fi
        done
        printf '\n  ],\n'
        printf '  "safetensors": {\n'
        printf '    "shard_count": %s,\n' "$shard_count"
        printf '    "total_source_bytes": %s\n' "$source_bytes"
        printf '  },\n'
        printf '  "resources": {\n'
        printf '    "disk_available_bytes": %s,\n' "$output_available_bytes"
        printf '    "disk_required_bytes": %s,\n' "$disk_required_bytes"
        printf '    "disk_estimate_rule": "2x source bytes for BF16 output plus conversion workspace",\n'
        printf '    "disk_sane": %s,\n' "$disk_sane"
        printf '    "ram_available_bytes": %s,\n' "$ram_available_bytes"
        printf '    "ram_required_bytes": %s,\n' "$ram_required_bytes"
        printf '    "ram_estimate_rule": "1.5x source bytes for conversion metadata and tensor streaming headroom",\n'
        printf '    "ram_sane": %s\n' "$ram_sane"
        printf '  },\n'
        printf '  "support": {\n'
        printf '    "config_supported": %s,\n' "$config_supported"
        printf '    "converter_supported": %s,\n' "$converter_supported"
        printf '    "gguf_constants_supported": %s,\n' "$gguf_supported"
        printf '    "runtime_supported": %s\n' "$runtime_supported"
        printf '  },\n'
        printf '  "conversion_started": false,\n'
        if [[ "$status" == "0" ]]; then
            printf '  "preflight_status": "pass"\n'
        else
            printf '  "preflight_status": "fail"\n'
        fi
        printf '}\n'
    } > "$report"

    jq '.' "$report"
    if [[ "$status" == "0" ]]; then
        ok "GGUF preflight passed. Conversion was not started."
    else
        echo "GGUF preflight failed. Conversion was not started."
    fi
    return "$status"
}

do_witness_gguf_convert() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        echo "Usage: ./dev witness-gguf-convert <model> [--output PATH] [--outtype bf16] [--force]"
        echo "  Converts a local safetensors model to BF16 GGUF only after the built preflight gate passes."
        echo "  Writes logs and conversion manifest under logs/witness-gguf-convert_*."
        echo "  Refuses to overwrite an existing expected output unless --force is supplied."
        echo "  Models: qwen35"
        return 0
    fi
    [[ $# -lt 1 ]] && err "Usage: ./dev witness-gguf-convert <model> [--output PATH] [--outtype bf16] [--force]"
    local model="$1"
    shift
    local output_override=""
    local outtype="bf16"
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)
                [[ $# -ge 2 ]] || err "--output requires a path"
                output_override="$2"
                shift 2
                ;;
            --outtype)
                [[ $# -ge 2 ]] || err "--outtype requires a value"
                outtype="$2"
                shift 2
                ;;
            --force)
                force=1
                shift
                ;;
            --help|-h)
                echo "Usage: ./dev witness-gguf-convert <model> [--output PATH] [--outtype bf16] [--force]"
                echo "  Converts a local safetensors model to BF16 GGUF only after the built preflight gate passes."
                echo "  Models: qwen35"
                return 0
                ;;
            *)
                err "Unknown witness-gguf-convert argument: $1"
                ;;
        esac
    done
    [[ "$outtype" == "bf16" ]] || err "Only --outtype bf16 is accepted for witness authority conversion"
    [[ -d "$WITNESS_REPO" ]] || err "llama-witness repo not found: $WITNESS_REPO"

    mapfile -t paths < <(witness_model_paths "$model")
    local model_dir="${paths[0]}"
    local expected_gguf="${paths[2]}"
    [[ -n "$output_override" ]] && expected_gguf="$output_override"
    local converter="$WITNESS_REPO/convert_hf_to_gguf.py"
    [[ -f "$converter" ]] || err "converter not found: $converter"

    local run_dir preflight_log convert_log manifest
    run_dir=$(create_run_dir "witness-gguf-convert")
    preflight_log="$run_dir/preflight.log"
    convert_log="$run_dir/converter.log"
    manifest="$run_dir/witness_gguf_conversion.json"
    info "Running BF16 GGUF witness conversion"
    info "Run dir: $run_dir"
    info "Preflight log: $preflight_log"
    info "Converter log: $convert_log"
    info "Manifest: $manifest"

    if [[ -e "$expected_gguf" && "$force" != "1" ]]; then
        {
            printf '{\n'
            printf '  "format": "krasis_witness_gguf_conversion",\n'
            printf '  "format_version": 1,\n'
            printf '  "model": "%s",\n' "$(json_escape "$model")"
            printf '  "source_model_path": "%s",\n' "$(json_escape "$model_dir")"
            printf '  "output_path": "%s",\n' "$(json_escape "$expected_gguf")"
            printf '  "outtype": "%s",\n' "$(json_escape "$outtype")"
            printf '  "conversion_started": false,\n'
            printf '  "exit_status": 1,\n'
            printf '  "failure_reason": "expected output already exists; rerun with --force to overwrite intentionally"\n'
            printf '}\n'
        } > "$manifest"
        err "Expected BF16 GGUF already exists: $expected_gguf
Use --force only if overwriting that witness artifact is intentional."
    fi

    local preflight_status=0
    set +e
    do_witness_gguf_preflight "$model" --output "$expected_gguf" --outtype "$outtype" 2>&1 | tee "$preflight_log"
    preflight_status=${PIPESTATUS[0]}
    set -e
    local preflight_report
    preflight_report=$(ls -td "$SCRIPT_DIR"/logs/witness-gguf-preflight_*/witness_gguf_preflight.json 2>/dev/null | head -1 || true)
    [[ -n "$preflight_report" && -f "$preflight_report" ]] || err "Preflight did not produce a report; see $preflight_log"
    if [[ "$preflight_status" != "0" ]]; then
        err "Preflight failed; conversion was not started. See $preflight_report and $preflight_log"
    fi
    jq -e '
      .preflight_status == "pass"
      and .conversion_started == false
      and .support.config_supported == true
      and .support.converter_supported == true
      and .support.gguf_constants_supported == true
      and .support.runtime_supported == true
      and .resources.disk_sane == true
      and .resources.ram_sane == true
    ' "$preflight_report" >/dev/null || err "Preflight report did not pass all support/resource gates: $preflight_report"

    if [[ -e "$expected_gguf" && "$force" != "1" ]]; then
        err "Expected BF16 GGUF appeared after preflight and --force was not supplied: $expected_gguf"
    fi
    if [[ -e "$expected_gguf" && "$force" == "1" ]]; then
        warn "Removing existing output because --force was supplied: $expected_gguf"
        rm -f "$expected_gguf"
    fi
    mkdir -p "$(dirname "$expected_gguf")"

    local converter_cmd start_ts end_ts exit_status
    printf -v converter_cmd '%q ' "$PYTHON" "$converter" "$model_dir" --outtype "$outtype" --outfile "$expected_gguf"
    converter_cmd="${converter_cmd% }"
    start_ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    info "Starting converter:"
    echo "  $converter_cmd"
    set +e
    (
        cd "$WITNESS_REPO"
        "$PYTHON" "$converter" "$model_dir" --outtype "$outtype" --outfile "$expected_gguf"
    ) 2>&1 | tee "$convert_log"
    exit_status=${PIPESTATUS[0]}
    set -e
    end_ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

    {
        printf '{\n'
        printf '  "format": "krasis_witness_gguf_conversion",\n'
        printf '  "format_version": 1,\n'
        printf '  "model": "%s",\n' "$(json_escape "$model")"
        printf '  "source_model_path": "%s",\n' "$(json_escape "$model_dir")"
        printf '  "output_path": "%s",\n' "$(json_escape "$expected_gguf")"
        printf '  "outtype": "%s",\n' "$(json_escape "$outtype")"
        printf '  "preflight_report": "%s",\n' "$(json_escape "$preflight_report")"
        printf '  "preflight_log": "%s",\n' "$(json_escape "$preflight_log")"
        printf '  "converter_log": "%s",\n' "$(json_escape "$convert_log")"
        printf '  "converter_command": "%s",\n' "$(json_escape "$converter_cmd")"
        printf '  "start_timestamp_utc": "%s",\n' "$start_ts"
        printf '  "end_timestamp_utc": "%s",\n' "$end_ts"
        printf '  "conversion_started": true,\n'
        printf '  "exit_status": %s,\n' "$exit_status"
        if [[ -f "$expected_gguf" ]]; then
            printf '  "output_exists": true,\n'
            printf '  "output_size_bytes": %s\n' "$(stat -c '%s' "$expected_gguf")"
        else
            printf '  "output_exists": false,\n'
            printf '  "output_size_bytes": null\n'
        fi
        printf '}\n'
    } > "$manifest"

    jq '.' "$manifest"
    if [[ "$exit_status" == "0" && -f "$expected_gguf" ]]; then
        ok "GGUF conversion complete: $expected_gguf"
    else
        echo "GGUF conversion failed. See $convert_log and $manifest"
    fi
    return "$exit_status"
}

do_witness_capture() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        echo "Usage: ./dev witness-capture <model> [--output PATH] [--reference PATH] [--profile ID] [--max-cases N] [validator args...]"
        echo "  Captures llama-witness JSON from stored input_token_ids only."
        echo "  Models: qcn, qwen35"
        return 0
    fi
    [[ $# -lt 1 ]] && err "Usage: ./dev witness-capture <model> [--output PATH] [--reference PATH] [--profile ID] [--max-cases N] [validator args...]
  Captures llama-witness JSON from stored input_token_ids only.
  Default profile: $WITNESS_PROFILE_ID"
    local model="$1"
    shift
    local output=""
    local reference_override=""
    local profile="$WITNESS_PROFILE_ID"
    local validator_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                echo "Usage: ./dev witness-capture <model> [--output PATH] [--reference PATH] [--profile ID] [--max-cases N] [validator args...]"
                echo "  Captures llama-witness JSON from stored input_token_ids only."
                echo "  Models: qcn, qwen35"
                return 0
                ;;
            --reference)
                [[ $# -ge 2 ]] || err "--reference requires a path"
                reference_override="$2"
                shift 2
                ;;
            --output)
                [[ $# -ge 2 ]] || err "--output requires a path"
                output="$2"
                shift 2
                ;;
            --profile)
                [[ $# -ge 2 ]] || err "--profile requires an id"
                profile="$2"
                shift 2
                ;;
            --max-cases)
                [[ $# -ge 2 ]] || err "--max-cases requires a count"
                validator_args+=(--max-cases "$2")
                shift 2
                ;;
            *)
                validator_args+=("$1")
                shift
                ;;
        esac
    done

    [[ -d "$WITNESS_REPO" ]] || err "llama-witness repo not found: $WITNESS_REPO"
    local script="$WITNESS_REPO/scripts/witness/validate_frozen_reference.sh"
    [[ -x "$script" ]] || err "witness script not executable: $script"

    mapfile -t paths < <(witness_model_paths "$model")
    local model_dir="${paths[0]}"
    local reference_json="${paths[1]}"
    local model_gguf="${paths[2]}"
    [[ -n "$reference_override" ]] && reference_json="$reference_override"
    [[ -d "$model_dir" ]] || err "witness model dir not found: $model_dir"
    [[ -f "$reference_json" ]] || err "input-token source reference not found: $reference_json"

    local run_dir
    run_dir=$(create_run_dir "witness-capture")
    if [[ -z "$output" ]]; then
        output="$run_dir/${model}_${profile}.json"
    fi
    mkdir -p "$(dirname "$output")"

    info "Running llama-witness capture"
    info "Run dir: $run_dir"
    info "Output: $output"
    (
        cd "$WITNESS_REPO"
        WITNESS_PROFILE_ID="$profile" \
        WITNESS_MAX_NEW_TOKENS="${KRASIS_WITNESS_MAX_NEW_TOKENS:-1}" \
        WITNESS_GENERATED_AT="${KRASIS_WITNESS_GENERATED_AT:-$(date -u '+%Y-%m-%dT%H:%M:%SZ')}" \
            "$script" "$model_dir" "$reference_json" "$model_gguf" \
            --json-output "$output" \
            --capture-only \
            "${validator_args[@]}"
    ) 2>&1 | tee "$run_dir/witness_capture.log"
    ok "Witness capture complete: $output"
}

