do_witness_model_check() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        echo "Usage: ./dev witness-model-check <model> [--hash]"
        echo "  Checks local readiness for BF16 llama-witness capture."
        echo "  Models: qcn, qwen35"
        echo "  --hash computes the GGUF SHA-256 when the expected BF16 file exists."
        return 0
    fi
    [[ $# -lt 1 ]] && err "Usage: ./dev witness-model-check <model> [--hash]"
    local model="$1"
    shift
    local do_hash=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --hash)
                do_hash=1
                shift
                ;;
            --help|-h)
                echo "Usage: ./dev witness-model-check <model> [--hash]"
                echo "  Checks local readiness for BF16 llama-witness capture."
                echo "  Models: qcn, qwen35"
                return 0
                ;;
            *)
                err "Unknown witness-model-check argument: $1"
                ;;
        esac
    done

    mapfile -t paths < <(witness_model_paths "$model")
    local model_dir="${paths[0]}"
    local default_reference_json="${paths[1]}"
    local model_gguf="${paths[2]}"
    local status=0

    info "Checking llama-witness model readiness for $model"
    echo "model_dir=$model_dir"
    if [[ -d "$model_dir" ]]; then
        ok "model_dir exists"
        for required in config.json tokenizer.json tokenizer_config.json generation_config.json; do
            if [[ -f "$model_dir/$required" ]]; then
                stat -c "  $required: %s bytes" "$model_dir/$required"
            else
                echo "  MISSING: $required"
                status=1
            fi
        done
    else
        echo "MISSING: model_dir"
        status=1
    fi

    echo "default_input_token_source=$default_reference_json"
    if [[ -f "$default_reference_json" ]]; then
        ok "default input-token source exists"
    else
        echo "MISSING: default input-token source"
        status=1
    fi

    echo "expected_bf16_gguf=$model_gguf"
    if [[ -f "$model_gguf" ]]; then
        stat -c "bf16_gguf_size_bytes=%s" "$model_gguf"
        ok "expected BF16 GGUF exists"
        if [[ "$do_hash" == "1" ]]; then
            sha256sum "$model_gguf"
        fi
    else
        echo "MISSING: expected BF16 GGUF"
        status=1
    fi

    if [[ "${model,,}" == qwen35 || "${model,,}" == q35b || "${model,,}" == qwen3.5-35b-a3b ]]; then
        local q4_path="$HOME/.krasis/models/Qwen3.5-35B-A3B-GGUF/Qwen3.5-35B-A3B-Q4_K_M.gguf"
        if [[ -f "$q4_path" ]]; then
            stat -c "non_authority_q4_gguf=$q4_path (%s bytes)" "$q4_path"
            echo "NOTE: Q4 GGUF is present but is not acceptable as a BF16 witness authority."
        fi
    fi

    if [[ "$status" == "0" ]]; then
        ok "Witness model readiness check passed"
    else
        echo "Witness model readiness check failed"
    fi
    return "$status"
}

do_hqq_attn_diff() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        echo "Usage: ./dev hqq-attn-diff <model> [--layer N] [--tensor in_proj_qkvz|in_proj_ba|out_proj|fused_qkv|q_proj|k_proj|v_proj|o_proj|cache-audit|source-map-audit|capture-plan|case-row-audit|named-row-divergence] [--output PATH]"
        echo "       [--top-rows N] [--top-groups N] [--sample-cols N]"
        echo "       [--input-row-trace PATH ...] [--input-row-pos N|all] [--case-summary PATH]"
        echo "       [--max-input-rows N]"
        echo "       [--focus-row N] [--focus-group N]"
        echo "       [--candidate-grid-steps N] [--candidate-local-grid-steps N]"
        echo "       [--bf16-trace PATH] [--hqq-trace PATH] [--bf16-summary PATH] [--hqq-summary PATH]"
        echo "  Offline reporting-only HQQ attention artifact diff, attribution, quantizer-choice, activation-aware what-if, decision-summary, and named-row divergence diagnostics."
        echo "  Currently supports qwen35 selected LA/GQA attention diagnostics, qcn/qwen35 cache/source-map audits, capture-plan reporting, and named-row divergence maps."
        return 0
    fi
    [[ $# -lt 1 ]] && err "Usage: ./dev hqq-attn-diff <model> [--layer N] [--tensor in_proj_qkvz|in_proj_ba|out_proj|fused_qkv|q_proj|k_proj|v_proj|o_proj|cache-audit|source-map-audit|capture-plan|case-row-audit|named-row-divergence] [--output PATH]"
    local model="$1"
    shift
    local layer=0
    local tensor="in_proj_qkvz"
    local output=""
    local top_rows=12
    local top_groups=12
    local sample_cols=8
    local input_row_traces=()
    local input_row_pos=36
    local case_summary=""
    local max_input_rows=""
    local focus_row=""
    local focus_group=""
    local candidate_grid_steps=129
    local candidate_local_grid_steps=65
    local bf16_trace=""
    local hqq_trace=""
    local bf16_summary=""
    local hqq_summary=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --layer)
                layer="${2:-}"
                [[ -n "$layer" ]] || err "--layer requires a value"
                shift 2
                ;;
            --tensor)
                tensor="${2:-}"
                [[ -n "$tensor" ]] || err "--tensor requires a value"
                shift 2
                ;;
            --output)
                output="${2:-}"
                [[ -n "$output" ]] || err "--output requires a value"
                shift 2
                ;;
            --top-rows)
                top_rows="${2:-}"
                [[ -n "$top_rows" ]] || err "--top-rows requires a value"
                shift 2
                ;;
            --top-groups)
                top_groups="${2:-}"
                [[ -n "$top_groups" ]] || err "--top-groups requires a value"
                shift 2
                ;;
            --sample-cols)
                sample_cols="${2:-}"
                [[ -n "$sample_cols" ]] || err "--sample-cols requires a value"
                shift 2
                ;;
            --input-row-trace)
                [[ -n "${2:-}" ]] || err "--input-row-trace requires a value"
                input_row_traces+=(--input-row-trace "$2")
                shift 2
                ;;
            --input-row-pos)
                input_row_pos="${2:-}"
                [[ -n "$input_row_pos" ]] || err "--input-row-pos requires a value"
                shift 2
                ;;
            --case-summary)
                case_summary="${2:-}"
                [[ -n "$case_summary" ]] || err "--case-summary requires a path"
                shift 2
                ;;
            --max-input-rows)
                max_input_rows="${2:-}"
                [[ -n "$max_input_rows" ]] || err "--max-input-rows requires a value"
                shift 2
                ;;
            --focus-row)
                focus_row="${2:-}"
                [[ -n "$focus_row" ]] || err "--focus-row requires a value"
                shift 2
                ;;
            --focus-group)
                focus_group="${2:-}"
                [[ -n "$focus_group" ]] || err "--focus-group requires a value"
                shift 2
                ;;
            --candidate-grid-steps)
                candidate_grid_steps="${2:-}"
                [[ -n "$candidate_grid_steps" ]] || err "--candidate-grid-steps requires a value"
                shift 2
                ;;
            --candidate-local-grid-steps)
                candidate_local_grid_steps="${2:-}"
                [[ -n "$candidate_local_grid_steps" ]] || err "--candidate-local-grid-steps requires a value"
                shift 2
                ;;
            --bf16-trace)
                bf16_trace="${2:-}"
                [[ -n "$bf16_trace" ]] || err "--bf16-trace requires a value"
                shift 2
                ;;
            --hqq-trace)
                hqq_trace="${2:-}"
                [[ -n "$hqq_trace" ]] || err "--hqq-trace requires a value"
                shift 2
                ;;
            --bf16-summary)
                bf16_summary="${2:-}"
                [[ -n "$bf16_summary" ]] || err "--bf16-summary requires a value"
                shift 2
                ;;
            --hqq-summary)
                hqq_summary="${2:-}"
                [[ -n "$hqq_summary" ]] || err "--hqq-summary requires a value"
                shift 2
                ;;
            --help|-h)
                echo "Usage: ./dev hqq-attn-diff <model> [--layer N] [--tensor in_proj_qkvz|in_proj_ba|out_proj|fused_qkv|q_proj|k_proj|v_proj|o_proj|cache-audit|source-map-audit|capture-plan|case-row-audit|named-row-divergence] [--output PATH]"
                echo "       [--top-rows N] [--top-groups N] [--sample-cols N]"
                echo "       [--input-row-trace PATH ...] [--input-row-pos N|all] [--case-summary PATH]"
                echo "       [--max-input-rows N]"
                echo "       [--focus-row N] [--focus-group N]"
                echo "       [--candidate-grid-steps N] [--candidate-local-grid-steps N]"
                echo "       [--bf16-trace PATH] [--hqq-trace PATH] [--bf16-summary PATH] [--hqq-summary PATH]"
                echo "  Offline reporting-only HQQ attention artifact diff, attribution, quantizer-choice, activation-aware what-if, decision-summary, and named-row divergence diagnostics."
                return 0
                ;;
            *)
                err "Unknown hqq-attn-diff argument: $1"
                ;;
        esac
    done
    case "$tensor" in
        in_proj_qkvz|in_proj_ba|out_proj|fused_qkv|q_proj|k_proj|v_proj|o_proj|cache-audit|source-map-audit|capture-plan|case-row-audit|named-row-divergence) ;;
        *) err "Only selected Qwen3.5 LA/GQA HQQ tensors, cache-audit, source-map-audit, capture-plan, or named-row-divergence are supported today" ;;
    esac
    local model_key="${model,,}"
    case "$model_key" in
        qcn|qwen3-coder-next)
            case "$tensor" in
                cache-audit|source-map-audit|capture-plan|case-row-audit) ;;
                *) err "qcn hqq-attn-diff currently supports audit-only tensors: cache-audit, source-map-audit, capture-plan" ;;
            esac
            ;;
        qwen35|q35b|qwen3.5-35b-a3b) ;;
        *) err "hqq-attn-diff currently supports qcn and qwen35" ;;
    esac
    mapfile -t paths < <(witness_model_paths "$model")
    local model_dir="${paths[0]}"
    local cache_dir
    case "$model_key" in
        qcn|qwen3-coder-next) cache_dir="$HOME/.krasis/cache/Qwen3-Coder-Next/attention_hqq_v5" ;;
        *) cache_dir="$HOME/.krasis/cache/Qwen3.5-35B-A3B/attention_hqq_v5" ;;
    esac
    [[ -d "$model_dir" ]] || err "model dir not found: $model_dir"
    [[ -d "$cache_dir" ]] || err "HQQ cache dir not found: $cache_dir"
    local run_dir
    run_dir=$(create_run_dir "hqq-attn-diff")
    if [[ -z "$output" ]]; then
        output="$run_dir/hqq_attention_diff.json"
    fi
    local tsv="${output%.json}.tsv"
    local input_row_args=()
    if [[ ${#input_row_traces[@]} -gt 0 ]]; then
        input_row_args=("${input_row_traces[@]}" --input-row-pos "$input_row_pos")
        if [[ -n "$case_summary" ]]; then
            input_row_args+=(--case-summary "$case_summary")
        fi
        if [[ -n "$max_input_rows" ]]; then
            input_row_args+=(--max-input-rows "$max_input_rows")
        fi
    fi
    local focus_args=()
    if [[ -n "$focus_row" || -n "$focus_group" ]]; then
        [[ -n "$focus_row" && -n "$focus_group" ]] || err "--focus-row and --focus-group must be supplied together"
        focus_args=(--focus-row "$focus_row" --focus-group "$focus_group")
    fi
    local named_row_args=()
    if [[ "$tensor" == "named-row-divergence" ]]; then
        [[ -n "$bf16_trace" && -n "$hqq_trace" ]] || err "named-row-divergence requires --bf16-trace and --hqq-trace"
        named_row_args=(--bf16-trace "$bf16_trace" --hqq-trace "$hqq_trace")
        if [[ -n "$bf16_summary" ]]; then
            named_row_args+=(--bf16-summary "$bf16_summary")
        fi
        if [[ -n "$hqq_summary" ]]; then
            named_row_args+=(--hqq-summary "$hqq_summary")
        fi
    fi
    info "Running offline HQQ attention diff"
    info "Run dir: $run_dir"
    verify_repo_imports
    KRASIS_DEV_SCRIPT=1 KRASIS_RUN_DIR="$run_dir" KRASIS_RUN_TYPE="hqq-attn-diff" run_repo_python \
        "$SCRIPT_DIR/tests/hqq_attention_diff.py" \
        --model-dir "$model_dir" \
        --cache-dir "$cache_dir" \
        --layer "$layer" \
        --tensor "$tensor" \
        --output "$output" \
        --tsv-output "$tsv" \
        --top-rows "$top_rows" \
        --top-groups "$top_groups" \
        --sample-cols "$sample_cols" \
        --candidate-grid-steps "$candidate_grid_steps" \
        --candidate-local-grid-steps "$candidate_local_grid_steps" \
        "${input_row_args[@]}" \
        "${focus_args[@]}" \
        "${named_row_args[@]}"
    ok "Wrote $output"
    ok "Wrote $tsv"
}

