    kill)       do_kill ;;
    chat)       verify_repo_imports; exec_repo_python -m krasis.chat "$@" ;;
    sanity)
        verify_repo_imports
        run_dir=$(create_run_dir "dev-sanity")
        info "Run dir: $run_dir"
        KRASIS_RUN_DIR="$run_dir" KRASIS_RUN_TYPE="dev-sanity" exec_repo_python -m krasis.chat --sanitytest "$@"
        ;;
    install)
        info "Installing krasis command to ~/.local/bin/krasis..."
        mkdir -p "$HOME/.local/bin"
        # Symlink so installed command is always identical to repo script
        rm -f "$HOME/.local/bin/krasis"
        ln -s "$SCRIPT_DIR/krasis" "$HOME/.local/bin/krasis"
        # Clean up any stale pip/venv artifacts
        rm -f "$HOME/.local/bin/krasis-chat" "$HOME/.local/bin/krasis-setup"
        rm -rf "$HOME/.krasis/venv"
