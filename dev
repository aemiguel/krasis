	        shift
	        local no_server=false
	        local arg
	        for arg in "$@"; do
	            if [[ "$arg" == "--no-server" ]]; then
	                no_server=true
	                break
	            fi
	        done
	        if [[ "$no_server" == true ]]; then
	            info "Reference test using existing server; skipping GPU cleanup/rebuild"
	        else
	            cleanup_gpu "$conf"
	            auto_rebuild
	        fi
	        local run_dir
	        run_dir=$(create_run_dir "reference-test")
        info "Running reference test: $conf"
        info "Run dir: $run_dir"
        verify_repo_imports
        KRASIS_DEV_SCRIPT=1 KRASIS_RUN_DIR="$run_dir" KRASIS_RUN_TYPE="reference-test" run_repo_python "$SCRIPT_DIR/tests/reference_test.py" "$conf" "$@"
    fi
}

