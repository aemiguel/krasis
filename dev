        rm -f "$HOME/.local/bin/krasis-chat" "$HOME/.local/bin/krasis-setup"
        rm -rf "$HOME/.krasis/venv"
        ok "Installed. 'krasis' command symlinked to $SCRIPT_DIR/krasis"
        ;;
    *)
        err "Unknown command: $cmd
  Run ./dev help for usage."
        ;;
esac
